# Bun
node_modules/
*.tsbuildinfo
bun.lock
# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Test outputs
/tmp/
*.backup-*

# Reports (regenerated)
plugins/migration-report.json
plugins/py-to-bun-report.json
plugins/scrub-report.json
plugins/validate-bun-report.json

# Python lint cache
.ruff_cache/
plugins/**/.ruff_cache/

# Bundled hooks — regenerated at setup by scripts/build-hooks.ts, never committed.
# The runtime lives in ~/.codex/node_modules/@fusengine/codex-hooks (a local tarball
# built + installed by the setup), so no bundle belongs in git.
#   - legacy per-plugin dev output (now unused; hooks.json read from the package):
plugins/*/dist/
#   - the @fusengine/codex-hooks package.json is tracked; its built per-plugin bundle
#     dirs (dev builds of `build-hooks all`) are not:
packages/codex-hooks/*/

# Plugin-bundled node_modules and lockfiles inside source plugins
plugins/*/scripts/node_modules/
plugins/*/scripts/bun.lock
plugins/*/statusline/node_modules/
plugins/*/statusline/dist/
plugins/*/statusline/bun.lock

# IDE
.vscode/
.idea/
*.swp

# Local agent session state
.claude/
.cartographer/
**/.cartographer/

# APEX tracking (auto-generated)
.codex/
portage
plugins/*/.cartographer
.harness/

# fuse-lessons dev memory — internal session notes, not package content.
/MEMORY/
