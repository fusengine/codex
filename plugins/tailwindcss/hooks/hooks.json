{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/check-tailwind-skill.native.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/validate-tailwind.native.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/track-skill-read.native.js"
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/track-mcp-research.native.js"
          }
        ]
      }
    ]
  }
}