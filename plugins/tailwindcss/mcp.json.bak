{
  "gemini-design": {
    "command": "npx",
    "args": [
      "-y",
      "gemini-design-mcp@latest"
    ],
    "env": {
      "API_KEY": "${GEMINI_DESIGN_API_KEY}"
    }
  },
  "sequential-thinking": {
    "command": "npx",
    "args": [
      "-y",
      "@modelcontextprotocol/server-sequential-thinking"
    ]
  },
  "context7": {
    "command": "npx",
    "args": [
      "-y",
      "@upstash/context7-mcp"
    ],
    "env": {
      "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
    }
  },
  "exa": {
    "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,get_code_context_exa,crawling_exa,company_research_exa,linkedin_search_exa,deep_researcher_start,deep_researcher_check",
    "env_http_headers": {
      "x-api-key": "${EXA_API_KEY}"
    }
  },
  "fuse-browser": {
    "command": "npx",
    "args": [
      "-y",
      "fuse-browser-mcp@latest"
    ]
  }
}
