{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_PLUGIN_ROOT}/scripts/auto-capture-error.ts"
          }
        ]
      },
      {
        "matcher": "mcp__graphiti|mcp__qdrant",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_PLUGIN_ROOT}/scripts/track-memory-ops.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_PLUGIN_ROOT}/scripts/recall-on-session.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_PLUGIN_ROOT}/scripts/capture-agent-lesson.ts"
          }
        ]
      }
    ]
  }
}