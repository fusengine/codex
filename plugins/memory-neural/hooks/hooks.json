{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_HOME}/node_modules/@fusengine/codex-hooks/memory-neural/hooks/auto-capture-error.native.js"
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_HOME}/node_modules/@fusengine/codex-hooks/memory-neural/hooks/track-memory-ops.native.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_HOME}/node_modules/@fusengine/codex-hooks/memory-neural/hooks/recall-on-session.native.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_HOME}/node_modules/@fusengine/codex-hooks/memory-neural/hooks/capture-agent-lesson.native.js"
          }
        ]
      }
    ]
  }
}
