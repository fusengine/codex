{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/generate_map.native.js ${PLUGIN_ROOT}/.. ${PLUGIN_ROOT}/../.cartographer || true; bun ${PLUGIN_ROOT}/dist/hooks/generate_project_map.native.js || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/track-enrichment.native.js || true"
          }
        ]
      }
    ]
  }
}