{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/generate_map.ts ${PLUGIN_ROOT}/.. ${PLUGIN_ROOT}/../.cartographer || true; bun ${PLUGIN_ROOT}/scripts/generate_project_map.ts || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/track-enrichment.ts || true"
          }
        ]
      }
    ]
  }
}