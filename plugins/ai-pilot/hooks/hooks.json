{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/detect-and-inject-apex.ts"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/detect-bash-write.ts"
          }
        ]
      },
      {
        "matcher": "Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/enforce-apex-phases.ts"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/inject-apex-context.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/cache-analytics-save.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/check-solid-compliance.ts"
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/track-doc-consultation.ts"
          }
        ]
      },
      {
        "matcher": "update_plan",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/sync-task-tracking.ts"
          }
        ]
      }
    ]
  }
}
