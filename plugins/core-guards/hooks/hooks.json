{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/_legacy_py/pre-tool-use/webfetch-cache-lookup.py"
          }
        ]
      },
      {
        "matcher": "context7|exa",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/_legacy_py/pre-tool-use/mcp-cache-lookup.py"
          }
        ]
      },
      {
        "matcher": "context7|exa",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/_legacy_py/pre-tool-use/limit-mcp-verbosity.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/pre-tool-use/bash-write-guard.native.js"
          },
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/pre-tool-use/git-guard.native.js"
          },
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/pre-tool-use/install-guard.native.js"
          },
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/pre-tool-use/security-guard.native.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/pre-tool-use/pre-commit-guard.ts"
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/pre-tool-use/enforce-interfaces.ts"
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/pre-tool-use/enforce-file-size.ts"
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/pre-tool-use/require-solid-read.native.js"
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/pre-tool-use/require-apex-agents.native.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "spawn_agent|multi_agent_v1.spawn_agent",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/post-tool-use/track-agent-calls.ts"
          }
        ]
      },
      {
        "matcher": "Bash|mcp__.*|mcp__context7__query-docs|mcp__context7__resolve-library-id|mcp__exa__web_search_exa|mcp__exa__get_code_context_exa|mcp__exa__deep_researcher_start",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/post-tool-use/track-subagent-research.ts"
          }
        ]
      },
      {
        "matcher": "context7|exa",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/post-tool-use/cache-mcp-result.ts"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/post-tool-use/auto-document-reads.ts"
          },
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/post-tool-use/track-solid-reads.ts"
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/post-tool-use/enforce-file-size.ts"
          },
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/post-tool-use/track-session-changes.ts"
          },
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/post-tool-use/post-edit-typescript.ts"
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/_legacy_py/post-tool-use/webfetch-cache-store.py"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/post-tool-use/log-tool-failure.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/session-start/inject-agents-md.ts"
          },
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/session-start/load-dev-context.ts"
          },
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/session-start/cleanup-session-states.ts"
          },
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/_legacy_py/session-start/cleanup-old-caches.py"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/instructions-loaded/validate-rules-loaded.ts"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/user-prompt/read-agents-md.ts"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/user-prompt/detect-creation-intent.ts"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/subagent-start/inject-context-cache.ts"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/subagent-stop/track-agent-memory.ts"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/teammate-idle/validate-teammate-output.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/task-completed/validate-task-solid.ts"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/sound/play.ts ${PLUGIN_ROOT}/song/finish.mp3"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/_legacy_py/task-completed/validate-apex-workflow.py",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/session-end/cleanup-session.ts"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/sound/play.ts ${PLUGIN_ROOT}/song/permission-need.mp3"
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/sound/play.ts ${PLUGIN_ROOT}/song/permission-need.mp3"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/sound/play.ts ${PLUGIN_ROOT}/song/need-human.mp3"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/sound/play.ts ${PLUGIN_ROOT}/song/need-human.mp3"
          }
        ]
      }
    ]
  }
}
