{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_PLUGIN_ROOT}/scripts/check-laravel-skill.ts"
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_PLUGIN_ROOT}/scripts/validate-laravel-solid.ts"
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_PLUGIN_ROOT}/scripts/validate-fusecore.ts"
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_PLUGIN_ROOT}/scripts/detect-duplication.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_PLUGIN_ROOT}/scripts/track-skill-read.ts"
          }
        ]
      },
      {
        "matcher": "mcp_tool_call",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_PLUGIN_ROOT}/scripts/track-mcp-research.ts"
          }
        ]
      }
    ]
  }
}
