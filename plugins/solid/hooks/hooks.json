{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_PLUGIN_ROOT}/scripts/detect-project.ts",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_PLUGIN_ROOT}/scripts/validate-solid.ts",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_PLUGIN_ROOT}/scripts/check-file-size.ts",
            "timeout": 10
          }
        ]
      }
    ]
  }
}