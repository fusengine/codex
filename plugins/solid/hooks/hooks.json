{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_HOME}/node_modules/@fusengine/codex-hooks/solid/hooks/detect-project.native.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_HOME}/node_modules/@fusengine/codex-hooks/solid/hooks/validate-solid.native.js",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CODEX_HOME}/node_modules/@fusengine/codex-hooks/solid/hooks/check-file-size.native.js",
            "timeout": 10
          }
        ]
      }
    ]
  }
}