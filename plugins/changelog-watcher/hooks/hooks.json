{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__.*exa|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CODEX_HOME:-$HOME/.codex}/node_modules/@fusengine/harness/dist/cli/bin.mjs\" hook codex changelog"
          }
        ]
      }
    ]
  }
}
