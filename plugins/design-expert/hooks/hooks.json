{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/guard-state-files.native.js"
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/enforce-html-css-only.native.js"
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/check-design-skill.native.js"
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/pipeline-gate.native.js"
          }
        ]
      },
      {
        "matcher": "mcp__fuse-browser__browser_navigate",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/check-inspiration-read.native.js"
          }
        ]
      },
      {
        "matcher": "mcp__fuse-browser__browser_screenshot",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/require-scroll-before-screenshot.native.js"
          }
        ]
      },
      {
        "matcher": "mcp__gemini-design__",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/pipeline-gate.native.js"
          }
        ]
      },
      {
        "matcher": "mcp__gemini-design__create_frontend",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/validate-design-system.native.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/track-skill-read.native.js"
          }
        ]
      },
      {
        "matcher": "mcp__fuse-browser__browser_screenshot",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/track-screenshot.native.js"
          }
        ]
      },
      {
        "matcher": "mcp__context7__|mcp__exa__|mcp__magic__|mcp__shadcn__|mcp__fuse-browser__|mcp__gemini-design__",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/track-mcp-research.native.js"
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/validate-design.native.js"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "design",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/design-agent-flag.native.js"
          }
        ]
      },
      {
        "matcher": "design",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/design-state-init.native.js"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "design",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/design-agent-flag.native.js"
          }
        ]
      },
      {
        "matcher": "design",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/dist/hooks/design-state-cleanup.native.js"
          }
        ]
      }
    ]
  }
}