{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/guard-state-files.ts"
          }
        ]
      },
      {
        "matcher": "Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/enforce-html-css-only.ts"
          }
        ]
      },
      {
        "matcher": "Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/check-design-skill.ts"
          }
        ]
      },
      {
        "matcher": "Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/pipeline-gate.ts"
          }
        ]
      },
      {
        "matcher": "mcp_tool_call",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/check-inspiration-read.ts"
          }
        ]
      },
      {
        "matcher": "mcp_tool_call",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/require-scroll-before-screenshot.ts"
          }
        ]
      },
      {
        "matcher": "mcp_tool_call",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/pipeline-gate.ts"
          }
        ]
      },
      {
        "matcher": "mcp_tool_call",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/validate-design-system.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/track-skill-read.ts"
          }
        ]
      },
      {
        "matcher": "mcp_tool_call",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/track-screenshot.ts"
          }
        ]
      },
      {
        "matcher": "mcp_tool_call",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/track-mcp-research.ts"
          }
        ]
      },
      {
        "matcher": "Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/validate-design.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/design-agent-flag.ts"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/design-state-init.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/design-agent-flag.ts"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${PLUGIN_ROOT}/scripts/design-state-cleanup.ts"
          }
        ]
      }
    ]
  }
}
